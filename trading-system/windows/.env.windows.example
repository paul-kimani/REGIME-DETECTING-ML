# ============================================================
# Windows .env — copy this to .env in the project root
# The key difference from Mac: MT5_BRIDGE_URL points to
# localhost because the bridge and trading system both run
# on this machine.
# ============================================================

# MT5 Bridge — runs on this machine, so always localhost
MT5_BRIDGE_URL=http://localhost:8000
MT5_BRIDGE_API_KEY=change_me_to_a_long_random_secret

# MT5 bridge IP allowlist — leave EMPTY when bridge and trading
# system run on the same machine (localhost bypasses the check)
MT5_ALLOWED_IP=
MT5_BRIDGE_HOST=0.0.0.0
MT5_BRIDGE_PORT=8000

# MT5 account credentials (optional — if not set, uses
# whatever account is already logged in to the MT5 terminal)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# PostgreSQL — running in Docker Desktop on this machine
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_user
DB_PASSWORD=change_me

# Redis — running in Docker Desktop on this machine
REDIS_URL=redis://localhost:6379

# MLflow — running in Docker Desktop on this machine
MLFLOW_TRACKING_URI=http://localhost:5000

# Risk overrides (leave blank to use YAML values)
MAX_RISK_PER_TRADE=
MAX_DAILY_LOSS=
PROP_FIRM_MODE=false

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
