# ============================================================
# .env.example — copy to .env and fill in your values
#
# MetaTrader5 connects DIRECTLY on Windows — no bridge, no HTTP.
# Leave MT5_LOGIN / MT5_PASSWORD / MT5_SERVER blank to use the
# account that is already logged in to the running MT5 terminal.
# ============================================================

# -----------------------------------------------------------
# MetaTrader 5 — direct connection (Windows only)
# -----------------------------------------------------------
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=your_broker_server_name
# Full path to terminal64.exe (optional — auto-detected if blank)
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# -----------------------------------------------------------
# PostgreSQL — running in Docker Desktop
# -----------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_user
DB_PASSWORD=change_me

# -----------------------------------------------------------
# Redis — running in Docker Desktop
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------
# MLflow — running in Docker Desktop
# -----------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# -----------------------------------------------------------
# Risk overrides (leave blank to use values from YAML configs)
# -----------------------------------------------------------
MAX_RISK_PER_TRADE=
MAX_DAILY_LOSS=
PROP_FIRM_MODE=false
PROP_FIRM_DAILY_LIMIT=0.05
PROP_FIRM_TOTAL_LIMIT=0.10

# -----------------------------------------------------------
# Telegram alerts (optional)
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
